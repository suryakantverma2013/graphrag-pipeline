# =============================================================================
# RAG Pipeline — environment configuration (template)
# Copy to `.env` and fill in real values. NEVER commit `.env` (NFR-SEC-1).
# Schema source of truth: REQUIREMENTS.md §2.5
# =============================================================================

# ----- OpenAI (cloud LLM + embeddings) -------------------------------------
OPENAI_API_KEY=sk-replace-me
# OPENAI_BASE_URL=                      # optional endpoint override (leave unset for OpenAI)

# ----- Neo4j (Docker container) --------------------------------------------
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me         # also consumed by docker-compose.yml
NEO4J_DATABASE=neo4j

# ----- Postgres checkpoint store (NATIVE on-prem install, D15) -------------
# Postgres runs natively on this laptop (localhost:5432), NOT in Docker.
# Use these when creating the local database + role (psql / pgAdmin),
# then keep them IN SYNC with CHECKPOINT_DB_URI below.
POSTGRES_USER=langgraph
POSTGRES_PASSWORD=please-change-me
POSTGRES_DB=langgraph
# Consumed by the application (LangGraph PostgresSaver):
CHECKPOINT_DB_URI=postgresql://langgraph:please-change-me@127.0.0.1:5432/langgraph

# ----- Models ---------------------------------------------------------------
LLM_MODEL=gpt-4o-mini                   # tagging + query reasoning (D1)
SYNTHESIS_MODEL=gpt-4o-mini             # answer synthesis; may be gpt-4o (D8)
EMBEDDING_MODEL=text-embedding-3-small  # shared ingest+query, 1536-dim (FR-Q0.5)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3  # local cross-encoder
RERANKER_DEVICE=cuda                    # GPU default; fallback "cpu" (FR-Q3.2a)
OCR_ENGINE=easyocr                      # locked (D6)
# Optional: Hugging Face token for higher download rate limits (exported to the
# process env by get_config so huggingface_hub uses it). Leave blank = anonymous.
HF_TOKEN=
# Local cache for Docling / BGE / EasyOCR weights (FR-S0.3):
HF_HOME=./.model_cache
# MODEL_CACHE_DIR=./.model_cache        # alias if your code reads this instead

# ----- Parsing / Docling (PDF memory & cost controls) ----------------------
# OCR is only needed for scanned/image PDFs and is the heaviest, most memory-
# hungry parse stage. Tri-state (normalized to auto|on|off):
#   auto  = the parse node classifies each PDF from its text layer and enables
#           OCR only for scanned/mixed files (no per-file tuning) — recommended.
#   on    = force OCR for every file (alias: true).
#   off   = never OCR (alias: false) — fast path for known born-digital PDFs.
OCR_ENABLED=auto                         # auto | on | off
# OCR languages (EasyOCR codes) used when OCR runs; comma/space-separated. Must
# be script-compatible (English combines with anything; can't mix e.g. Chinese +
# Arabic). Non-Latin scans: e.g. "ch_sim,en" | "ja,en" | "ar,en" | "ru,en" | "hi,en".
OCR_LANGUAGES=fr,de,es,en                # default = EasyOCR's built-in Latin set
PDF_MAX_PAGES=0                          # 0 = all pages; e.g. 50 = parse first 50 pages only
PDF_RENDER_DPI=72                        # born-digital DPI (layout backdrop); lower (e.g. 48) = less memory
# DPI used WHEN OCR IS ACTIVE: the scanned bitmap is the only text source, so
# render sharper for legibility (small math/diacritics). Costs memory/time
# (~dpi^2); if a high DPI OOMs, lower PDF_PARSE_BATCH_PAGES_OCR to compensate.
PDF_RENDER_DPI_OCR=150                   # 72 = old behavior; 150 good; 200+ sharper but heavier
# Parse very large PDFs in page-range slices so Docling frees memory between
# slices (it OOMs ~page 127 regardless of DPI). 0 = single convert (legacy).
PDF_PARSE_BATCH_PAGES=100                # slice size for born-digital PDFs (no OCR)
PDF_PARSE_BATCH_PAGES_OCR=12             # smaller slice when OCR is active (heavier/page + sharper DPI)

# ----- Tunables (defaults from the diagrams / decisions) -------------------
CHUNK_MAX_TOKENS=512                     # FR-3.4
CHUNK_OVERLAP_TOKENS=50                  # FR-3.4
EMBED_BATCH_SIZE=100                     # FR-6.2
# Chunks written per Neo4j transaction (FR-7.1). The per-doc write used to be ONE
# transaction; on very large books it grew to ~240k store commands and Neo4j
# failed to apply it, wedging the DB. Chunks are now written in batches of this
# size (one tx each); a failure deletes the partial doc (FR-7.8). Lower if writes
# still strain on huge chunks.
NEO4J_WRITE_BATCH_CHUNKS=250             # FR-7.1
TAG_CONFIDENCE_THRESHOLD=0.5            # FR-4.7
REFINE_CONFIDENCE_THRESHOLD=0.6         # FR-Q1.4
ESCALATE_CONFIDENCE_THRESHOLD=0.38      # FR-Q3.5 (calibrated; see calibrate_confidence.py)
PER_RETRIEVER_K=25                       # D11 / FR-Q2.6
RETRIEVE_TOP_K=50                        # D11 / FR-Q2.6
RERANK_TOP_K=10                          # D11 / FR-Q3.3
MAX_CLARIFICATION_ROUNDS=2               # D12 / FR-Q1.6
MAX_SUBQUERIES=5                         # D12 / FR-Q1.10

# ----- Logging (NFR-LOG) ----------------------------------------------------
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                          # json | text
LOG_DIR=./logs                           # rotating-file location (git-ignored)
